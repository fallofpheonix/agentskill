{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StrictTriEngineArtifacts",
  "definitions": {
    "Repository": {
      "type": "object",
      "required": ["root_path", "tracked_files", "timestamp"],
      "properties": {
        "root_path": {
          "type": "string",
          "minLength": 1
        },
        "tracked_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "RepoInventory": {
      "type": "object",
      "required": ["components", "dependencies", "timestamp"],
      "properties": {
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "type", "role", "path"],
            "properties": {
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["module", "service", "tool", "config", "doc", "test"]
              },
              "role": {
                "type": "string",
                "enum": ["core", "framework", "utility", "deprecated"]
              },
              "path": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "ConflictReport": {
      "type": "object",
      "required": ["unresolved_dependencies", "overlaps", "timestamp"],
      "properties": {
        "unresolved_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "overlaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["components", "conflict_type"],
            "properties": {
              "components": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string" }
              },
              "conflict_type": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "DeletionPlan": {
      "type": "object",
      "required": ["deletions", "rationale", "timestamp"],
      "properties": {
        "deletions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "reason"],
            "properties": {
              "path": { "type": "string" },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "PatchedCodebase": {
      "type": "object",
      "required": ["modifications", "removals", "timestamp"],
      "properties": {
        "modifications": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["file_path", "change_type", "change_summary"],
            "properties": {
              "file_path": { "type": "string" },
              "change_type": {
                "type": "string",
                "enum": ["create", "update", "delete"]
              },
              "change_summary": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "removals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "EnforcedContract": {
      "type": "object",
      "required": ["execution_dag", "stage_transitions", "timestamp"],
      "properties": {
        "execution_dag": {
          "type": "object"
        },
        "stage_transitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["from_stage", "to_stage", "gate_condition"],
            "properties": {
              "from_stage": { "type": "string" },
              "to_stage": { "type": ["string", "null"] },
              "gate_condition": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "ValidationReport": {
      "type": "object",
      "required": ["test_results", "build_status", "security_status", "timestamp"],
      "properties": {
        "test_results": {
          "type": "object",
          "required": ["passed", "failed", "skipped"],
          "properties": {
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "skipped": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "build_status": {
          "type": "string",
          "enum": ["success", "failure"]
        },
        "security_status": {
          "type": "string",
          "enum": ["clean", "warnings", "failures"]
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "ChangeRecord": {
      "type": "object",
      "required": ["summary", "details", "timestamp"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
