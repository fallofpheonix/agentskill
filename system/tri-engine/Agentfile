FROM python:3.11-slim
FRAMEWORK fast-agent
MODEL anthropic/claude-3-sonnet-20241022

SECRET ANTHROPIC_API_KEY

WORKDIR /workspace

AGENT antigravity
INSTRUCTION Classify repository state, enforce stage ordering, and reject undocumented scope changes.
SERVERS filesystem commands
USE_HISTORY true
HUMAN_INPUT false

AGENT codex
INSTRUCTION Apply code and configuration changes only after required input artifacts exist.
SERVERS filesystem commands
USE_HISTORY true
HUMAN_INPUT false

AGENT opencode
INSTRUCTION Run validation gates, security checks, and reject unverifiable output.
SERVERS filesystem commands
USE_HISTORY true
HUMAN_INPUT false

ORCHESTRATOR tri_engine_cicd
AGENTS antigravity codex opencode
PLAN_TYPE full
PLAN_ITERATIONS 8
STAGE_SCHEMA stages.yaml
DEFAULT 1
INSTRUCTION Execute only the stages declared in stages.yaml. Reject missing inputs, duplicate outputs, or undeclared stage transitions.

SERVER filesystem
COMMAND npx
ARGS -y @modelcontextprotocol/server-filesystem /workspace
TRANSPORT stdio

SERVER commands
COMMAND npx
ARGS -y mcp-server-commands
TRANSPORT stdio

CMD ["python", "agent.py"]
